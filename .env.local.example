# ─── Supabase ──────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API

# Your project URL (e.g. https://abcdefghijkl.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — NEVER expose this publicly, server-side only
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ───────────────────────────────────────────────────────────────────
# Local development: http://localhost:3000
# Production: https://your-app.vercel.app  (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
